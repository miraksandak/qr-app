{% extends "base.html.twig" %}

{% block title %}Access Configuration{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/hotel-picker.js') }}" defer></script>
    <script src="{{ asset('js/access.js') }}" defer></script>
{% endblock %}

{% block body %}
    {% set missingLabels = {
        portalUrl: 'Portal URL',
        pmsProvider: 'PMS',
        pmsCredentialFields: 'PMS fields',
        ssids: 'SSID list'
    } %}
    {% set pmsFieldLabels = {
        roomNumber: 'Room Number',
        surname: 'Surname',
        firstName: 'First Name',
        checkinNumber: 'Check-in Number',
        password: 'Password'
    } %}
    {% set pmsFieldDefaults = {
        roomNumber: '606',
        surname: 'Doe',
        firstName: 'John',
        checkinNumber: '123456',
        password: 'guest-pass'
    } %}
    {% set config = selectedHotelState.configuration ?? null %}

    <main class="app-shell">
        <header class="app-topbar">
            <div class="app-topbar__brand">
                <div class="brand-lockup">
                    <div class="brand-lockup__badge brand-lockup__badge--topbar">
                        <img class="brand-lockup__logo" src="{{ asset('media/mik-logo.png') }}" alt="Mikenopa">
                    </div>
                </div>
                <div class="app-topbar__copy">
                    <p class="page-head__eyebrow">QR Access</p>
                    <strong>Standalone Connector App</strong>
                    <p>Hotels loaded via OAuth.</p>
                </div>
            </div>
            <div class="app-topbar__meta">
                <div class="app-user">
                    <p class="page-head__eyebrow">Logged In As</p>
                    <strong>{{ user.displayName }}</strong>
                </div>
                <span class="pill">{{ hotelBrowser.pagination.total }} hotel{{ hotelBrowser.pagination.total == 1 ? '' : 's' }}</span>
                {% if selectedHotel and (not selectedHotelState or not selectedHotelState.meta.persisted) %}
                    <span class="pill pill--warning">Default On First Create</span>
                {% endif %}
                <a class="app-logout" href="{{ path('app_logout') }}">
                    <svg class="app-logout__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M15 16l4-4-4-4"/>
                        <path d="M19 12H10"/>
                        <path d="M10 4H7a2 2 0 0 0-2 2v3"/>
                        <path d="M5 15v3a2 2 0 0 0 2 2h3"/>
                    </svg>
                    <span>Logout</span>
                </a>
            </div>
        </header>

        <nav class="app-tabs" aria-label="Primary">
            <a class="app-tab app-tab--active" href="{{ path('app_access', selectedHotel ? {hotel: selectedHotel.externalHotelId} : {}) }}">Access</a>
            {% if permissions.hotelSettings %}
                <a class="app-tab" href="{{ path('app_hotel_settings', selectedHotel ? {hotel: selectedHotel.externalHotelId} : {}) }}">Hotel Settings</a>
            {% endif %}
        </nav>

        <div class="app-main">
            <header class="page-head page-head--page">
                <div>
                    <h1 class="page-head__title">Access Document</h1>
                </div>
                <p class="page-head__copy">Create one access document for the selected hotel.</p>
            </header>

            <section class="panel panel--selector">
                <form method="get" action="{{ path('app_access') }}" class="selector-form selector-form--picker" data-hotel-picker>
                    <div class="hotel-picker">
                        <div class="field">
                            <label for="hotel-search">Hotel</label>
                            <input
                                id="hotel-search"
                                class="input hotel-picker__search"
                                type="search"
                                name="q"
                                value="{{ hotelBrowser.query }}"
                                placeholder="Type to filter or press Enter to search all hotels"
                                autocomplete="off"
                                data-hotel-filter
                            >
                            <p class="field-help hotel-picker__status" data-hotel-filter-status></p>
                        </div>
                        <select id="hotel-selector" class="input hotel-picker__select" name="hotel" data-hotel-select onchange="this.form.submit()">
                            {% for hotel in hotelBrowser.items %}
                                <option value="{{ hotel.externalHotelId }}" {% if selectedHotel and hotel.externalHotelId == selectedHotel.externalHotelId %}selected{% endif %}>
                                    {{ hotel.displayName ?: hotel.externalHotelId }}
                                </option>
                            {% else %}
                                <option value="">No hotels on this page</option>
                            {% endfor %}
                        </select>
                    </div>
                </form>

                <div class="selector-summary">
                    {% if selectedHotel %}
                        <div>
                            <span class="selector-summary__label">Selected hotel</span>
                            <strong>{{ selectedHotel.displayName }}</strong>
                        </div>
                        <div>
                            <span class="selector-summary__label">External ID</span>
                            <code>{{ selectedHotel.externalHotelId }}</code>
                        </div>
                    {% endif %}
                    <div>
                        <span class="selector-summary__label">Page</span>
                        <strong>{{ hotelBrowser.pagination.page }}/{{ hotelBrowser.pagination.pageCount }}</strong>
                    </div>
                </div>

                {% if hotelBrowser.pagination.pageCount > 1 %}
                    <nav class="pager" aria-label="Hotel pages">
                        {% if hotelBrowser.pagination.page > 1 %}
                            <a class="button" href="{{ path('app_access', {
                                q: hotelBrowser.query,
                                page: hotelBrowser.pagination.page - 1
                            }) }}">Previous 50</a>
                        {% endif %}
                        {% if hotelBrowser.pagination.page < hotelBrowser.pagination.pageCount %}
                            <a class="button" href="{{ path('app_access', {
                                q: hotelBrowser.query,
                                page: hotelBrowser.pagination.page + 1
                            }) }}">Next 50</a>
                        {% endif %}
                    </nav>
                {% endif %}
            </section>

            {% if hotelBrowser.pagination.total == 0 %}
                <section class="panel">
                    <div class="notice notice--warning">No hotels match the current search.</div>
                </section>
            {% elseif selectedHotel %}
                <div class="content-grid content-grid--aside">
                    <div class="content-stack">
                        <section class="panel">
                            <div class="panel-head">
                                <div>
                                    <p class="panel-head__eyebrow">Primary Workflow</p>
                                    <h3>Create Document</h3>
                                </div>
                                <p class="panel-head__copy">Uses saved hotel defaults.</p>
                            </div>

                            {% if (selectedHotelState and not selectedHotelState.meta.persisted) or selectedHotelState.meta.missingConfigurationFields is not empty %}
                                <div class="notice-stack">
                                    {% if selectedHotelState and not selectedHotelState.meta.persisted %}
                                        <div class="notice notice--warning">No local configuration yet. Safe defaults will be created on first document.</div>
                                    {% endif %}

                                    {% if selectedHotelState.meta.missingConfigurationFields is not empty %}
                                        <div class="notice notice--warning">
                                            Hotel setup is incomplete:
                                            {{ selectedHotelState.meta.missingConfigurationFields|map(field => missingLabels[field] ?? field)|join(', ') }}.
                                            Access codes stay disabled until this is filled in.
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}

                            <form
                                id="access-form"
                                class="form"
                                data-create-url="{{ path('app_api_manual_create') }}"
                                data-selected-hotel-id="{{ selectedHotel.externalHotelId }}"
                                data-access-code-allowed="{{ selectedHotelState.meta.accessCodeAllowed ? '1' : '0' }}"
                            >
                                <div class="grid grid--two">
                                    <div class="field">
                                        <label for="validUntil">Valid Until</label>
                                        <input id="validUntil" class="input" type="text" placeholder="2026-03-01T12:00:00+00:00">
                                    </div>
                                    <div class="field">
                                        <label for="authMode">Primary Option</label>
                                        <select id="authMode" class="input">
                                            <option value="roomSurname" {% if config.primaryAuthMode == 'roomSurname' or not selectedHotelState.meta.accessCodeAllowed %}selected{% endif %}>Room + PMS data</option>
                                            <option value="accessCode" {% if config.primaryAuthMode == 'accessCode' and selectedHotelState.meta.accessCodeAllowed %}selected{% endif %} {% if not selectedHotelState.meta.accessCodeAllowed %}disabled{% endif %}>Access Code</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="field field--inline">
                                    <label><input id="freeEnabled" type="checkbox"> Enable free access</label>
                                </div>

                                <section id="roomSurnameFields" class="option-card">
                                    <div class="option-card__head">
                                        <span class="pill">Option</span>
                                        <h4>Room + PMS Data</h4>
                                    </div>
                                    <div class="grid grid--two">
                                        {% for fieldName in config.pmsCredentialFields %}
                                            <div class="field">
                                                <label for="pmsField_{{ fieldName }}">{{ pmsFieldLabels[fieldName] ?? fieldName }}</label>
                                                <input
                                                    id="pmsField_{{ fieldName }}"
                                                    class="input"
                                                    type="{{ fieldName == 'password' ? 'password' : 'text' }}"
                                                    data-pms-field="{{ fieldName }}"
                                                    value="{{ pmsFieldDefaults[fieldName] ?? '' }}"
                                                >
                                            </div>
                                        {% endfor %}
                                    </div>
                                    <p class="field-help">Configured PMS: {{ config.pmsProvider ?: 'not selected yet' }}</p>
                                </section>

                                <section id="accessCodeFields" class="option-card hidden">
                                    <div class="option-card__head">
                                        <span class="pill">Option</span>
                                        <h4>Access Code</h4>
                                    </div>
                                    <div class="grid grid--one">
                                        <div class="field">
                                            <label for="accessCode">Access Code</label>
                                            <input id="accessCode" class="input" type="text" value="ABCD-1234">
                                        </div>
                                    </div>
                                </section>

                                <div id="form-error" class="notice notice--error hidden"></div>

                                <div class="actions">
                                    <button class="button button--primary" type="submit">Create Access Document</button>
                                    {% if permissions.hotelSettings %}
                                        <a class="button" href="{{ path('app_hotel_settings', {hotel: selectedHotel.externalHotelId}) }}">Open Hotel Configuration</a>
                                    {% endif %}
                                </div>
                            </form>
                        </section>

                        <section id="result-panel" class="panel hidden">
                            <div class="panel-head">
                                <div>
                                    <p class="panel-head__eyebrow">Created</p>
                                    <h3>Document Links</h3>
                                </div>
                            </div>

                            <div class="result-grid">
                                <a id="result-viewer" class="result-card" href="#" target="_blank" rel="noreferrer">
                                    <span>Viewer</span>
                                    <strong></strong>
                                </a>
                                <a id="result-json" class="result-card" href="#" target="_blank" rel="noreferrer">
                                    <span>JSON</span>
                                    <strong></strong>
                                </a>
                                <a id="result-print" class="result-card" href="#" target="_blank" rel="noreferrer">
                                    <span>Print</span>
                                    <strong></strong>
                                </a>
                            </div>
                        </section>
                    </div>

                    <aside class="content-stack content-stack--side">
                        <section class="panel panel--compact">
                            <div class="panel-head panel-head--compact">
                                <div>
                                    <p class="panel-head__eyebrow">Quick Open</p>
                                    <h3>Open Existing</h3>
                                </div>
                            </div>
                            <p class="panel-copy">Open a document by ID.</p>
                            <form id="open-form" class="stack-form">
                                <input id="open-id" class="input" type="text" maxlength="5" placeholder="ABCDE" autocomplete="off">
                                <button class="button" type="submit">Open Viewer</button>
                            </form>
                        </section>

                        <section class="panel panel--compact">
                            <div class="panel-head panel-head--compact">
                                <div>
                                    <p class="panel-head__eyebrow">Configuration</p>
                                    <h3>Status</h3>
                                </div>
                            </div>
                            <p class="panel-copy">
                                {% if selectedHotelState.meta.configurationComplete %}
                                    Hotel configuration is complete.
                                {% else %}
                                    Fill in the missing configuration fields before using access codes.
                                {% endif %}
                            </p>
                        </section>
                    </aside>
                </div>
            {% endif %}
        </div>
    </main>
{% endblock %}

{% extends 'manual/base.html.twig' %}
{% trans_default_domain 'manual' %}

{% block title %}{{ 'ui.upgradeTitle'|trans }}{% endblock %}

{% block body %}
    <main class="sheet">
        <div class="lang-switch" aria-label="{{ 'ui.languageSelector'|trans }}">
            <label for="langSelect" class="lang-switch__label" data-i18n="language">{{ 'ui.language'|trans }}</label>
            <select id="langSelect" class="lang-switch__select">
                <option value="en" data-i18n="localeEn">{{ 'ui.localeEn'|trans }}</option>
                <option value="cs" data-i18n="localeCs">{{ 'ui.localeCs'|trans }}</option>
            </select>
        </div>

        <header class="header">
            <div class="brand">
                <img id="hotel-logo" src="" alt="" class="logo hidden" />
                <div id="hotel-name" class="brandline"></div>
            </div>

            <div class="heading">
                <h1 data-i18n="upgradeTitle">{{ 'ui.upgradeTitle'|trans }}</h1>
                <p class="subtitle">
                    <span data-i18n="connectTo">{{ 'ui.connectTo'|trans }}</span>
                    <strong id="hotel-ssid">Hotel-Guest</strong>
                    <span data-i18n="wifiLabel">{{ 'ui.wifiLabel'|trans }}</span>
                </p>
            </div>
        </header>

        <section id="upgrade-panel" class="card">
            <div class="card__bar">
                <div class="card__left">
                    <span class="opt" data-i18n="upgradeLabel">{{ 'ui.upgradeLabel'|trans }}</span>
                    <span id="upgrade-title" class="opt__title">{{ 'ui.upgradeCardTitle'|trans }}</span>
                </div>
            </div>
            <div class="card__body upgrade__body">
                <div>
                    <p id="upgrade-body" class="upgrade__text">{{ 'ui.upgradeBody'|trans }}</p>
                </div>
            </div>
        </section>

        <footer class="footer">
            <div id="support-text">{{ 'ui.supportFallback'|trans }}</div>
            <div id="footer-brand" class="muted">{{ 'ui.footerFallback'|trans }}</div>
        </footer>

        <section id="load-error" class="error hidden">
            <h2 data-i18n="upgradeUnavailable">{{ 'ui.upgradeUnavailable'|trans }}</h2>
            <p data-i18n="upgradeUnavailableBody">{{ 'ui.upgradeUnavailableBody'|trans }}</p>
        </section>
    </main>
{% endblock %}

<!DOCTYPE html>
<html lang="{{ initialLang|default('en') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Guest Wi-Fi Manual{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('css/manual.css') }}">
        <script src="{{ asset('manual.js') }}" defer></script>
    </head>
    <body data-manual-id="{{ id }}" data-page="{{ page }}" data-base-upgrade-url="{{ baseUpgradeUrl }}" data-base-viewer-url="{{ baseViewerUrl }}" data-initial-lang="{{ initialLang|default('en') }}">
        <script id="manual-i18n" type="application/json">{{ manualI18n|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }}</script>
        {% block body %}{% endblock %}
    </body>
</html>

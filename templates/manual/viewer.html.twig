{% extends 'manual/base.html.twig' %}
{% trans_default_domain 'manual' %}

{% block title %}{{ 'ui.title'|trans }}{% endblock %}

{% block body %}
    <main class="sheet">
        {% if page != 'print' %}
            <div class="sheet-tools">
                <a class="sheet-tool" href="{{ path('manual_print', {id: id}) }}" target="_blank" rel="noreferrer">
                    <svg class="sheet-tool__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M7 8V4h10v4"/>
                        <rect x="5" y="9" width="14" height="7" rx="2"/>
                        <path d="M7 14h10v6H7z"/>
                        <path d="M16 11h1"/>
                    </svg>
                    <span class="sheet-tool__label" data-i18n="printPdf">{{ 'ui.printPdf'|trans }}</span>
                </a>
            </div>
        {% endif %}

        <div class="lang-switch" aria-label="{{ 'ui.languageSelector'|trans }}">
            <label for="langSelect" class="lang-switch__label" data-i18n="language">{{ 'ui.language'|trans }}</label>
            <select id="langSelect" class="lang-switch__select">
                <option value="en" data-i18n="localeEn">{{ 'ui.localeEn'|trans }}</option>
                <option value="cs" data-i18n="localeCs">{{ 'ui.localeCs'|trans }}</option>
            </select>
        </div>

        <header class="header">
            <div class="brand">
                <img id="hotel-logo" src="" alt="" class="logo hidden" />
                <div id="hotel-name" class="brandline"></div>
            </div>

            <div class="heading">
                <h1 data-i18n="title">{{ 'ui.title'|trans }}</h1>
                <p class="subtitle">
                    <span data-i18n="connectTo">{{ 'ui.connectTo'|trans }}</span>
                    <strong id="hotel-ssid">Hotel-Guest</strong>         
                    <span class="dot hidden">•</span>
                    <span id="portal-host" class="hidden"></span>
                </p>
                <p id="portal-warning" class="subtitle subtitle--warning hidden" data-i18n="portalMissing">{{ 'ui.portalMissing'|trans }}</p>
            </div>
        </header>

        <div class="manual-overview">
            <div class="manual-overview__meta">
                <section class="device">
                    <div class="device__label" data-i18n="deviceLabel">{{ 'ui.deviceLabel'|trans }}</div>
                    <div id="device-buttons" class="device-buttons"></div>
                </section>

                <section id="ssid-section" class="device hidden">
                    <div class="device__label" data-i18n="ssidLabel">{{ 'ui.ssidLabel'|trans }}</div>
                    <div id="ssid-buttons" class="device-buttons"></div>
                </section>
            </div>

            <section class="steps">
                <div class="steps__label" data-i18n="stepsLabel">{{ 'ui.stepsLabel'|trans }}</div>
                <ol id="steps-list" class="steps-list"></ol>
            </section>
        </div>

        <section class="list">
            <div id="auth-variants" class="list"></div>
            <article id="free-card" class="card card--free hidden">
                <div class="card__bar">
                    <div class="card__left">
                        <span class="opt opt--free" data-i18n="option3">{{ 'ui.option3'|trans }}</span>
                        <span class="opt__title" data-i18n="freeAccess">{{ 'ui.freeAccess'|trans }}</span>
                    </div>
                    <div class="card__right" data-i18n="noDetails">{{ 'ui.noDetails'|trans }}</div>
                </div>

                <div class="card__body card__body--single">
                    <div class="dataCol">
                        <div class="dataGrid">
                            <div class="dataBox">
                                <div class="dataLabel" data-i18n="networkLabel">{{ 'ui.networkLabel'|trans }}</div>
                                <div id="free-ssid-value" class="dataValue mono">—</div>
                            </div>
                            <div class="dataBox">
                                <div class="dataLabel" data-i18n="action">{{ 'ui.action'|trans }}</div>
                                <div class="dataValue" data-i18n-html="tapConnectContinue">{{ 'ui.tapConnectContinue'|trans|raw }}</div>
                            </div>
                        </div>
                        <div class="cta" data-i18n="online">{{ 'ui.online'|trans }}</div>
                    </div>
                </div>
            </article>
        </section>

        <section id="upgrade-card" class="card upgrade hidden">
            <div class="card__bar">
                <div class="card__left">
                    <span class="opt" data-i18n="upgradeLabel">{{ 'ui.upgradeLabel'|trans }}</span>
                    <span id="upgrade-title" class="opt__title">{{ 'ui.upgradeCardTitle'|trans }}</span>
                </div>
            </div>
            <div class="card__body upgrade__body">
                <div>
                    <p id="upgrade-body" class="upgrade__text">{{ 'ui.upgradeBody'|trans }}</p>
                    <a id="upgrade-link" class="upgrade__link" href="#" data-i18n="openUpgrade">{{ 'ui.openUpgrade'|trans }}</a>
                </div>
            </div>
        </section>

        <footer class="footer">
            <div id="support-text">{{ 'ui.supportFallback'|trans }}</div>
            <div id="footer-brand" class="muted">{{ 'ui.footerFallback'|trans }}</div>
        </footer>

        <section id="load-error" class="error hidden">
            <h2 data-i18n="manualUnavailable">{{ 'ui.manualUnavailable'|trans }}</h2>
            <p data-i18n="manualUnavailableBody">{{ 'ui.manualUnavailableBody'|trans }}</p>
        </section>
    </main>
{% endblock %}

{% extends "base.html.twig" %}

{% block title %}Manual Viewer Builder{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/main.css') }}">
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('main.js') }}" defer></script>
{% endblock %}

{% block body %}
    <main class="page">
        <header class="hero">
            <div>
                <p class="eyebrow">Captive Portal Manual</p>
                <h1>Manual Viewer Builder</h1>
                <p class="subtitle">Create a manual without curl, then open the viewer or JSON endpoint instantly.</p>
            </div>
            <div class="hero-card">
                <h2>Quick Links</h2>
                <p>Paste an ID to open an existing manual.</p>
                <form id="open-form" class="inline-form">
                    <input id="open-id" class="input" type="text" maxlength="5" placeholder="ABCDE" autocomplete="off">
                    <button class="button" type="submit">Open Viewer</button>
                </form>
            </div>
        </header>

        <section class="panel">
            <div class="panel-header">
                <h2>Create Manual</h2>
                <p>Configure hotel defaults separately, then create the specific access output you need.</p>
            </div>
            <form id="manual-form" class="form">
                <div class="field">
                    <label for="apiKey">API Key</label>
                    <input id="apiKey" class="input" type="text" value="dev-local-key" autocomplete="off">
                </div>
                <section class="form-section" aria-labelledby="hotel-config-heading">
                    <div class="section-header">
                        <div>
                            <h3 id="hotel-config-heading">Hotel Configuration</h3>
                            <p class="section-copy">Store the reusable hotel defaults here, then reload them whenever you create a new manual.</p>
                        </div>
                        <div class="section-actions">
                            <button class="button" type="button" id="loadHotelConfig">Load Hotel</button>
                            <button class="button" type="button" id="saveHotelConfig">Save Hotel</button>
                        </div>
                    </div>

                    <div class="grid two">
                        <div class="field">
                            <label for="hotelExternalId">External Hotel ID</label>
                            <input id="hotelExternalId" class="input" type="text" placeholder="f7768642-f895-11e8-99a6-005056a52682">
                        </div>
                        <div class="field">
                            <label for="hotelName">Hotel Name</label>
                            <input id="hotelName" class="input" type="text" value="Mikenopa">
                        </div>
                        <div class="field">
                            <label for="hotelSupport">Support Text</label>
                            <input id="hotelSupport" class="input" type="text" value="Need help? Contact reception.">
                        </div>
                        <div class="field">
                            <label for="hotelFooter">Footer Text</label>
                            <input id="hotelFooter" class="input" type="text" placeholder="Optional footer for the manual">
                        </div>
                        <div class="field">
                            <label for="hotelLogo">Logo URL</label>
                            <input id="hotelLogo" class="input" type="text" value="/media/mik-logo.png">
                        </div>
                    </div>

                    <details id="advancedHotelSettings" class="advanced-block">
                        <summary class="advanced-block__summary">
                            <span>Advanced</span>
                            <span class="advanced-block__hint">Uses defaults when empty</span>
                        </summary>
                        <div class="grid three advanced-grid">
                            <div class="field">
                                <label for="portalUrl">Guest Portal URL</label>
                                <input id="portalUrl" class="input" type="text" placeholder="https://guest-portal.example.com">
                            </div>
                            <div class="field">
                                <label for="proxyApiBaseUrl">Proxy API Base URL</label>
                                <input id="proxyApiBaseUrl" class="input" type="text" placeholder="https://proxy.example.com">
                            </div>
                            <div class="field">
                                <label for="datacenterId">Routing Key</label>
                                <input id="datacenterId" class="input" type="text" placeholder="central">
                            </div>
                        </div>
                    </details>

                    <div class="grid three">
                        <div class="field">
                            <label for="ssidPms">SSID (Room/PMS)</label>
                            <input id="ssidPms" class="input" type="text" value="Hotel-Guest" placeholder="Hotel-Guest, Guest-2">
                        </div>
                        <div class="field">
                            <label for="ssidAccess">SSID (Access code)</label>
                            <input id="ssidAccess" class="input" type="text" placeholder="Optional, comma-separated">
                        </div>
                        <div class="field">
                            <label for="ssidFree">SSID (Free access)</label>
                            <input id="ssidFree" class="input" type="text" placeholder="Optional, comma-separated">
                        </div>
                    </div>

                    <div class="grid two">
                        <div class="field">
                            <label for="deviceDefault">Default Device</label>
                            <select id="deviceDefault" class="input">
                                <option value="android">Android</option>
                                <option value="ios">iOS</option>
                                <option value="generic" selected>Generic</option>
                            </select>
                        </div>
                        <div class="field">
                            <span class="label">Available Devices</span>
                            <div class="checkbox-row">
                                <label><input type="checkbox" name="deviceAvailable" value="android" checked> Android</label>
                                <label><input type="checkbox" name="deviceAvailable" value="ios" checked> iOS</label>
                                <label><input type="checkbox" name="deviceAvailable" value="generic" checked> Generic</label>
                            </div>
                        </div>
                    </div>

                    <div class="panel-sub">
                        <div class="field">
                            <label><input id="upgradeEnabled" type="checkbox"> Upgrade enabled</label>
                        </div>
                        <div class="grid two">
                            <div class="field">
                                <label for="upgradeUrl">Upgrade URL (optional)</label>
                                <input id="upgradeUrl" class="input" type="text" placeholder="https://upgrade.example.com">
                            </div>
                        </div>
                    </div>

                    <div id="hotel-status" class="notice hidden"></div>
                </section>

                <section class="form-section form-section-accent" aria-labelledby="access-scenario-heading">
                    <div class="section-header">
                        <div>
                            <h3 id="access-scenario-heading">Access Configuration</h3>
                            <p class="section-copy">Only the fields for the selected primary option stay active in the final payload.</p>
                        </div>
                    </div>

                    <div class="grid two">
                        <div class="field">
                            <label for="validUntil">Valid Until</label>
                            <input id="validUntil" class="input" type="text" placeholder="2026-03-01T12:00:00+00:00">
                        </div>
                        <div class="field">
                            <label for="authMode">Primary Option</label>
                            <select id="authMode" class="input">
                                <option value="roomSurname" selected>Option 1 - Room + Surname</option>
                                <option value="accessCode">Option 2 - Access Code</option>
                            </select>
                        </div>
                    </div>

                    <div class="field">
                        <label><input id="freeEnabled" type="checkbox"> Enable free access (Option 3)</label>
                    </div>

                    <div id="roomSurnameFields" class="option-panel">
                        <div class="option-panel-header">
                            <span class="section-chip">Primary Option</span>
                            <h4>Room + Surname</h4>
                            <p>Use this mode when the guest authenticates with room number and surname.</p>
                        </div>
                        <div class="grid two">
                            <div class="field">
                                <label for="roomNumber">Room Number</label>
                                <input id="roomNumber" class="input" type="text" value="606">
                            </div>
                            <div class="field">
                                <label for="surname">Surname</label>
                                <input id="surname" class="input" type="text" value="Doe">
                            </div>
                        </div>
                    </div>

                    <div id="accessCodeFields" class="option-panel hidden">
                        <div class="option-panel-header">
                            <span class="section-chip">Primary Option</span>
                            <h4>Access Code</h4>
                            <p>Use this mode when the captive portal is driven by a generated access code instead of PMS data.</p>
                        </div>
                        <div class="grid two">
                            <div class="field">
                                <label for="accessCode">Access Code</label>
                                <input id="accessCode" class="input" type="text" value="ABCD-1234">
                            </div>
                        </div>
                    </div>
                </section>

                <div class="actions">
                    <button class="button primary" type="submit">Create Manual</button>
                    <button class="button" type="button" id="resetForm">Reset</button>
                </div>

                <div id="form-error" class="error hidden"></div>
            </form>
        </section>

        <section id="result-panel" class="panel hidden">
            <div class="panel-header">
                <h2>Created</h2>
                <p>Use these links to open the manual.</p>
            </div>
            <div class="result-grid">
                <div>
                    <div class="result-label">Viewer</div>
                    <a id="result-viewer" class="result-link" href="#" target="_blank" rel="noreferrer"></a>
                </div>
                <div>
                    <div class="result-label">JSON</div>
                    <a id="result-json" class="result-link" href="#" target="_blank" rel="noreferrer"></a>
                </div>
                <div>
                    <div class="result-label">Print</div>
                    <a id="result-print" class="result-link" href="#" target="_blank" rel="noreferrer"></a>
                </div>
                <div>
                    <div class="result-label">Upgrade</div>
                    <a id="result-upgrade" class="result-link" href="#" target="_blank" rel="noreferrer"></a>
                </div>
            </div>
        </section>
    </main>
{% endblock %}

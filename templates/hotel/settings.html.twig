{% extends "base.html.twig" %}

{% block title %}Hotel Configuration{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/hotel-settings.js') }}" defer></script>
{% endblock %}

{% block body %}
    <main class="app-shell">
        <header class="app-topbar">
            <div class="app-topbar__brand">
                <div class="brand-lockup">
                    <div class="brand-lockup__badge brand-lockup__badge--topbar">
                        <img class="brand-lockup__logo" src="{{ asset('media/mik-logo.png') }}" alt="Mikenopa">
                    </div>
                </div>
                <div class="app-topbar__copy">
                    <p class="page-head__eyebrow">QR Access</p>
                    <strong>Standalone Connector App</strong>
                    <p>Reusable defaults for each hotel.</p>
                </div>
            </div>
            <div class="app-topbar__meta">
                <div class="app-user">
                    <p class="page-head__eyebrow">Logged In As</p>
                    <strong>{{ user.displayName }}</strong>
                </div>
                <span class="pill">{{ accessibleHotels|length }} hotel{{ accessibleHotels|length == 1 ? '' : 's' }}</span>
                {% if selectedHotel and (not selectedHotelState or not selectedHotelState.meta.persisted) %}
                    <span class="pill pill--warning">Preview Defaults</span>
                {% endif %}
                <a class="app-logout" href="{{ path('app_logout') }}">
                    <svg class="app-logout__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M15 16l4-4-4-4"/>
                        <path d="M19 12H10"/>
                        <path d="M10 4H7a2 2 0 0 0-2 2v3"/>
                        <path d="M5 15v3a2 2 0 0 0 2 2h3"/>
                    </svg>
                    <span>Logout</span>
                </a>
            </div>
        </header>

        <nav class="app-tabs" aria-label="Primary">
            <a class="app-tab" href="{{ path('app_access', selectedHotel ? {hotel: selectedHotel.externalHotelId} : {}) }}">Access</a>
            <a class="app-tab app-tab--active" href="{{ path('app_hotel_settings', selectedHotel ? {hotel: selectedHotel.externalHotelId} : {}) }}">Hotel Settings</a>
        </nav>

        <div class="app-main">
            <header class="page-head page-head--page">
                <div>
                    <h1 class="page-head__title">Hotel Configuration</h1>
                </div>
                <p class="page-head__copy">Edit reusable defaults for the selected hotel.</p>
            </header>

            <section class="panel panel--selector">
                <form method="get" action="{{ path('app_hotel_settings') }}" class="selector-form">
                    <div class="field">
                        <label for="hotel-selector">Hotel</label>
                        <select id="hotel-selector" class="input" name="hotel" onchange="this.form.submit()">
                            {% for hotel in accessibleHotels %}
                                <option value="{{ hotel.externalHotelId }}" {% if selectedHotel and hotel.externalHotelId == selectedHotel.externalHotelId %}selected{% endif %}>
                                    {{ hotel.name ?: hotel.externalHotelId }}
                                </option>
                            {% else %}
                                <option value="">No accessible hotels</option>
                            {% endfor %}
                        </select>
                    </div>
                </form>

                {% if selectedHotel %}
                    <div class="selector-summary">
                        <div>
                            <span class="selector-summary__label">Selected hotel</span>
                            <strong>{{ selectedHotel.displayName }}</strong>
                        </div>
                        <div>
                            <span class="selector-summary__label">External ID</span>
                            <code>{{ selectedHotel.externalHotelId }}</code>
                        </div>
                    </div>
                {% endif %}
            </section>

            {% if accessibleHotels is empty %}
                <section class="panel">
                    <div class="notice notice--warning">The connector login succeeded, but no accessible hotels were returned for this user.</div>
                </section>
            {% elseif selectedHotel and selectedHotelState %}
                <section class="panel">
                    <div class="panel-head">
                        <div>
                            <p class="panel-head__eyebrow">Reusable Defaults</p>
                            <h3>Edit Settings</h3>
                        </div>
                        <p class="panel-head__copy">Saved here and reused for new documents.</p>
                    </div>

                    <form
                        id="hotel-settings-form"
                        class="form"
                        data-save-url="{{ path('app_api_hotel_upsert', {externalHotelId: selectedHotel.externalHotelId}) }}"
                    >
                        <div class="grid grid--two">
                            <div class="field">
                                <label for="hotelName">Hotel Name</label>
                                <input id="hotelName" class="input" type="text" value="{{ selectedHotelState.hotel.name ?? '' }}">
                            </div>
                            <div class="field">
                                <label for="hotelLogo">Logo URL</label>
                                <input id="hotelLogo" class="input" type="text" value="{{ selectedHotelState.configuration.logoUrl ?? '' }}">
                            </div>
                            <div class="field">
                                <label for="hotelSupport">Support Text</label>
                                <input id="hotelSupport" class="input" type="text" value="{{ selectedHotelState.configuration.supportText ?? '' }}">
                            </div>
                            <div class="field">
                                <label for="hotelFooter">Footer Text</label>
                                <input id="hotelFooter" class="input" type="text" value="{{ selectedHotelState.configuration.footerText ?? '' }}">
                            </div>
                        </div>

                        <details id="advancedHotelSettings" class="advanced-block" {% if selectedHotelState.configuration.portalUrl or selectedHotelState.configuration.proxyApiBaseUrl or selectedHotelState.configuration.datacenterId %}open{% endif %}>
                            <summary class="advanced-block__summary">
                                <span>Advanced</span>
                                <span class="advanced-block__hint">Only when the hotel needs it</span>
                            </summary>
                            <div class="grid grid--three">
                                <div class="field">
                                    <label for="portalUrl">Portal URL</label>
                                    <input id="portalUrl" class="input" type="text" value="{{ selectedHotelState.configuration.portalUrl ?? '' }}">
                                </div>
                                <div class="field">
                                    <label for="proxyApiBaseUrl">Proxy API Base URL</label>
                                    <input id="proxyApiBaseUrl" class="input" type="text" value="{{ selectedHotelState.configuration.proxyApiBaseUrl ?? '' }}">
                                </div>
                                <div class="field">
                                    <label for="datacenterId">Routing Key</label>
                                    <input id="datacenterId" class="input" type="text" value="{{ selectedHotelState.configuration.datacenterId ?? '' }}">
                                </div>
                            </div>
                        </details>

                        <div class="grid grid--three">
                            <div class="field">
                                <label for="ssidPms">SSID (Room/PMS)</label>
                                <input id="ssidPms" class="input" type="text" value="{{ selectedHotelState.configuration.ssids|filter(ssid => ssid.usage == 'pms')|map(ssid => ssid.name)|join(', ') }}">
                            </div>
                            <div class="field">
                                <label for="ssidAccess">SSID (Access code)</label>
                                <input id="ssidAccess" class="input" type="text" value="{{ selectedHotelState.configuration.ssids|filter(ssid => ssid.usage == 'ac')|map(ssid => ssid.name)|join(', ') }}">
                            </div>
                            <div class="field">
                                <label for="ssidFree">SSID (Free access)</label>
                                <input id="ssidFree" class="input" type="text" value="{{ selectedHotelState.configuration.ssids|filter(ssid => ssid.usage == 'free')|map(ssid => ssid.name)|join(', ') }}">
                            </div>
                        </div>

                        <div class="grid grid--two">
                            <div class="field">
                                <label for="authMode">Primary Option</label>
                                <select id="authMode" class="input">
                                    <option value="roomSurname" {% if selectedHotelState.configuration.primaryAuthMode == 'roomSurname' %}selected{% endif %}>Room + Surname</option>
                                    <option value="accessCode" {% if selectedHotelState.configuration.primaryAuthMode == 'accessCode' %}selected{% endif %}>Access Code</option>
                                </select>
                            </div>
                            <div class="field">
                                <label for="deviceDefault">Default Device</label>
                                <select id="deviceDefault" class="input">
                                    <option value="android" {% if selectedHotelState.configuration.device.default == 'android' %}selected{% endif %}>Android</option>
                                    <option value="ios" {% if selectedHotelState.configuration.device.default == 'ios' %}selected{% endif %}>iOS</option>
                                    <option value="generic" {% if selectedHotelState.configuration.device.default == 'generic' %}selected{% endif %}>Generic</option>
                                </select>
                            </div>
                        </div>

                        <div class="field">
                            <span class="field__label">Available Devices</span>
                            <div class="checkbox-row">
                                <label><input type="checkbox" name="deviceAvailable" value="android" {% if 'android' in selectedHotelState.configuration.device.available %}checked{% endif %}> Android</label>
                                <label><input type="checkbox" name="deviceAvailable" value="ios" {% if 'ios' in selectedHotelState.configuration.device.available %}checked{% endif %}> iOS</label>
                                <label><input type="checkbox" name="deviceAvailable" value="generic" {% if 'generic' in selectedHotelState.configuration.device.available %}checked{% endif %}> Generic</label>
                            </div>
                        </div>

                        <div class="field field--inline">
                            <label><input id="upgradeEnabled" type="checkbox" {% if selectedHotelState.configuration.upgrade.enabled %}checked{% endif %}> Upgrade enabled</label>
                        </div>

                        <div class="field">
                            <label for="upgradeUrl">Upgrade URL</label>
                            <input id="upgradeUrl" class="input" type="text" value="{{ selectedHotelState.configuration.upgrade.url ?? '' }}">
                        </div>

                        <div id="hotel-status" class="notice hidden"></div>

                        <div class="actions">
                            <button class="button button--primary" type="submit">Save Hotel Configuration</button>
                            <a class="button" href="{{ path('app_access', {hotel: selectedHotel.externalHotelId}) }}">Back To Access</a>
                        </div>
                    </form>
                </section>
            {% endif %}
        </div>
    </main>
{% endblock %}

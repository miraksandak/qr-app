#!/bin/bash

set -e

cd "`dirname "$0"`/.."

refs=()
if [ -f .env ]; then
    refs+=(-r .env)
fi

if [ -f .env.my ]; then
    refs+=(-r .env.my)
fi

(
    echo '# Warning: Do not edit this file directly. All changes will be overriden.'
    echo '# Write to .env.my instead. All variables from this file will be put here.'
    echo
    set -a
    test -f .env.my && source .env.my
    envfile -o - "${refs[@]}"
) > .env.local

bash -c '
    source .env
    source .env.local
    if [ "$APP_ENV" = "prod" ]; then
        composer dump-env
    else
        rm -f .env.local.php
    fi
'
